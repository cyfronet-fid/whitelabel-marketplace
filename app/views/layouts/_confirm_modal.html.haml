%dialog#confirm.confirm-modal
  .row
    .col-12.col-md-11
    .col-12.col-md-1
      %button.close.modal__backdrop.confirm-cancel.float-right{ type: "button" }
        %span{ aria: { hidden: "true" } } &times;
  .row
    .col-12
      .modal__content
        %h3.confirm-title Are you sure?
        .confirm-body
      .modal-actions
        %button#dismiss-btn.btn.btn-secondary.close.modal__backdrop.confirm-cancel{ type: "button" }
          Cancel
        %button#confirm-accept.btn.btn-primary{ data_e2e: "modal-confirm" } Yes, I'm Sure
