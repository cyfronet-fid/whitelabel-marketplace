- content_for :title, @provider.name
- breadcrumb :backoffice_provider, @provider

%h1= @provider.name
.status-row
  %span Status:
  %span.font-weight-bold
    = @provider.status

.service-box.p-4.mt-3.backoffice-form
  .logo-wrapper
    %span.helper
    - if @provider.logo.attached? && @provider.logo.variable?
      = image_tag @provider.logo.variant(resize: "100x67"), class: "align-self-center mr-4 float-left img-responsive"
    - else
      = image_tag "eosc-img.png", size: "100x67", class: "align-self-center mr-4 float-left img-responsive"
  - unless @provider.sources.empty?
    %h3
      = _("External Sources:")
    %ul
      - @provider.sources.each do |source|
        %li "#{source.source_type}: #{source.eid}"
  %hr.bottom-hr.mt-5.mb-4
  .btn-group
    - if policy([:backoffice, @provider]).edit?
      = link_to _("Edit"),
                edit_backoffice_provider_path(@provider),
                class: "btn btn-primary"
    - if policy([:backoffice, @provider]).publish?
      = link_to _("Publish"),
                backoffice_provider_publish_path(@provider),
                class: "btn btn-primary",
                data: { turbo_confirm: _("Are you sure you want to publish this provider?"),
                turbo_method: :post }
    - if policy([:backoffice, @provider]).suspend?
      = link_to _("Suspend"),
                backoffice_provider_unpublish_path(@provider, suspend: true),
                class: "btn btn-info",
                data: { turbo_confirm: _("Are you sure you want to publish this provider as suspended?"),
                turbo_method: :post }
    - if policy([:backoffice, @provider]).unpublish?
      = link_to _("Unpublish"),
                backoffice_provider_unpublish_path(@provider),
                class: "btn btn-error",
                data: { turbo_confirm: _("Are you sure you want to unpublish this provider?"),
                turbo_method: :post }
    - if policy([:backoffice, @provider]).destroy?
      = link_to _("Delete"),
                backoffice_provider_path(@provider),
                class: "btn btn-danger",
                data: { turbo_confirm: _("Are you sure you want to remove this provider?"), turbo_method: :delete }
