.row
  .col-12.col-xl-12
    %ul#my-tab.nav.nav-tabs.row.pl-3{ role: "tablist" }
      - provider_tabs.each_with_index do |tab, i|
        %li.nav-item
          = link_to _(tab.capitalize), { tab: tab },
            class: "nav-link #{"active" if params[:tab] == tab || (params[:tab].blank? && i.zero?) }",
            role: "tab",
            data: { e2e: "provider-#{tab}-btn", turbo_stream: true }
